# AridaiPos global backend — muhit o'zgaruvchilari namunasi
# Haqiqiy qiymatlar .env faylda (git'ga tushmaydi)

NODE_ENV=development
PORT=4322

# MongoDB (single-node replica set tavsiya — transaction + change stream uchun)
MONGO_URL=mongodb://127.0.0.1:27017/aridai_pos

# Maxfiy kalitlar — qarang obsidian/02-arxitektura/xavfsizlik/secrets-management.md
JWT_SECRET=__almashtiring__
BRANCH_SECRET=__almashtiring__

# Token muddatlari (ixtiyoriy)
USER_TOKEN_TTL=7d
REFRESH_TTL=30d
BRANCH_TTL=365d
