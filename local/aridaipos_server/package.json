{
  "name": "aridai-local-server",
  "version": "0.4.5",
  "private": true,
  "type": "module",
  "main": "src/main/index.js",
  "description": "AridaiPOS Local Server — filial offline backend (Express + lokal MongoDB) + VPS sync + status UI (Electron)",
  "scripts": {
    "backend": "node src/main/backend/server.js",
    "dev:renderer": "vite",
    "build:renderer": "vite build",
    "electron": "electron .",
    "dev": "concurrently -k -n renderer,electron -c green,blue \"npm:dev:renderer\" \"npm:electron\"",
    "start": "npm run build:renderer && electron .",
    "build:win": "npm run build:renderer && electron-builder --win",
    "build:mac": "npm run build:renderer && electron-builder --mac"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "electron-updater": "^6.8.3",
    "express": "^5.2.1",
    "express-rate-limit": "^7.4.1",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.6.2",
    "multer": "^2.1.1",
    "pdf-to-printer": "^5.8.0",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1",
    "uuid": "^11.0.3"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^9.0.1",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "puppeteer": "^24.43.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vite": "^5.4.8"
  },
  "build": {
    "appId": "com.aridai.localserver",
    "productName": "AridaiPOS Local Server",
    "publish": [
      {
        "provider": "github",
        "owner": "Shukurulla",
        "repo": "aridai-pos",
        "channel": "server"
      }
    ],
    "directories": {
      "output": "dist-app",
      "buildResources": "build"
    },
    "files": [
      "src/main/**/*",
      "src/preload/**/*",
      "dist/renderer/**/*"
    ],
    "asarUnpack": [
      "**/node_modules/pdf-to-printer/**"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "mac": {
      "target": [
        "dmg"
      ]
    }
  }
}
