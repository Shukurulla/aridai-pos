{
  "name": "aridaipos-monitor",
  "version": "0.3.5",
  "private": true,
  "type": "module",
  "main": "src/main/index.js",
  "description": "AridaiPOS Monitor — POS terminal (kassa) UI (Electron). Local serverga (aridaipos_server, 4561) ulanadi.",
  "scripts": {
    "dev:renderer": "vite",
    "build:renderer": "vite build",
    "electron": "electron .",
    "dev": "concurrently -k -n renderer,electron -c green,blue \"npm:dev:renderer\" \"npm:electron\"",
    "start": "npm run build:renderer && electron .",
    "build:win": "npm run build:renderer && electron-builder --win",
    "build:mac": "npm run build:renderer && electron-builder --mac"
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2",
    "socket.io-client": "^4.8.1",
    "uuid": "^11.0.3"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^9.0.1",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "vite": "^5.4.8"
  },
  "build": {
    "appId": "com.aridai.posmonitor",
    "productName": "AridaiPOS Monitor",
    "publish": [
      {
        "provider": "github",
        "owner": "Shukurulla",
        "repo": "aridai-pos",
        "channel": "monitor"
      }
    ],
    "directories": {
      "output": "dist-app",
      "buildResources": "build"
    },
    "files": [
      "src/main/**/*",
      "src/preload/**/*",
      "dist/renderer/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "mac": {
      "target": [
        "dmg"
      ]
    }
  }
}
